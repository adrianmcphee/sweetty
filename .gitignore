# --- OS files ---
.DS_Store
Thumbs.db

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.claude/

# --- Go build artifacts ---
/sweetty
/sweetty.exe
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.prof
*.coverprofile
coverage.txt
dist/
build/
bin/

# Generator binary (cmd/genfs) if built in place
/cmd/genfs/genfs

# --- Go workspace (local only; this repo is a single module) ---
go.work
go.work.sum

# --- Runtime artifacts ---
# config.json is generated by `sweetty init`/`gentoken` and holds the portal
# token bcrypt hashes; operator state, never source.
/config.json
config.local.json
# Per-instance randomized identity. Generated on first run; never in source.
/persona.json

# Captured attacker data. The log is everything an attacker typed and every
# payload they reached for. It must never enter version control.
*.log
logs/
# Embedded fakeroot log files are SOURCE content (part of the fake host), not
# runtime logs, so they must be tracked despite the *.log rule above.
!internal/fakehost/**/*.log

# Asciinema session replays (per-session forensic captures).
*.cast

# --- TLS material ---
# Self-signed certs are generated at runtime; example/fixture certs are allowed.
*.pem
*.crt
*.key
!*.example.pem
!*.example.crt
!*.example.key

# --- Temp / scratch ---
tmp/
temp/
*.tmp
*.bak
